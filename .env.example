# Link do botão "COMEÇAR AGORA" na página de oferta (checkout/pagamento)
# PUBLIC_CHECKOUT_URL=https://pay.hotmart.com/...

# PostHog (analytics)
PUBLIC_POSTHOG_KEY=phc_your-posthog-key

# Supabase (quiz session tracking)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # server-side only (webhooks)

# Meta Ads → Supabase (Edge Function sync-meta-insights; secrets no Dashboard da função)
# META_ACCESS_TOKEN=  # token com ads_read (Marketing API)
# Uma conta: META_AD_ACCOUNT_ID=311490276062263
# Várias contas (recomendado): META_AD_ACCOUNT_IDS=111111111,222222222,333333333
# META_AD_ACCOUNT_IDS=
# Fuso de relatório na função sync-meta-insights: fixo America/Sao_Paulo (não configurável por env).
# Janela sem since/until: last_hour (padrão) = última hora em SP; today = dia inteiro em SP
# META_INSIGHTS_WINDOW=last_hour
# META_GRAPH_VERSION=v23.0
# META_SYNC_CRON_SECRET=...  # opcional: se definir, toda chamada precisa Authorization: Bearer <mesmo valor>
# Insights async (quando a Meta devolve job em vez de data imediata):
# META_INSIGHTS_ASYNC_MAX_WAIT_MS=120000   # default 120s; aumente se jobs forem lentos (respeite o timeout da Edge Function)
# META_INSIGHTS_ASYNC_POLL_MS=2000         # intervalo entre polls do report run
# RESEND_API_KEY=re_your-resend-api-key
